# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/hireiq_db

# Upload Directory
UPLOAD_DIR=./uploads

# AI Configuration (Optional - System works without these)
# Use OpenAI for AI evaluation
OPENAI_API_KEY=sk-your-openai-key-here

# OR use Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# JWT Secret for Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Application Settings
APP_NAME=HireIQ
APP_VERSION=1.0.0
DEBUG=true

# Parsing Configuration
MAX_RESUME_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,docx,txt
MAX_SKILLS_PER_RESUME=100
MIN_PARSING_CONFIDENCE=0.6

# Scoring Weights (must sum to 100)
WEIGHT_SKILLS=40
WEIGHT_EXPERIENCE=25
WEIGHT_EDUCATION=10
WEIGHT_INDUSTRY=10
WEIGHT_CERTIFICATIONS=10
WEIGHT_LOCATION=5

# Background Processing
ENABLE_BACKGROUND_PROCESSING=true
MAX_CONCURRENT_PARSING=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/hireiq.log
