# HireIQ Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# AI API Keys (Optional - System works without these)
# ============================================================================

# Option 1: Use OpenAI for AI evaluation
# OPENAI_API_KEY=sk-your-openai-key-here

# Option 2: Use Anthropic Claude for AI evaluation
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Note: If neither is set, system uses rule-based evaluation (works fine!)

# ============================================================================
# Production Settings (Only needed for production deployment)
# ============================================================================

# Strong secret key for JWT tokens (generate with: openssl rand -hex 32)
# SECRET_KEY=your-super-secret-key-change-this-in-production

# Production database URL (if not using Docker's database)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# Development Settings (Docker uses defaults)
# ============================================================================

# These are set automatically by docker-compose.yml
# Only uncomment if running without Docker

# DATABASE_URL=postgresql://hireiq:hireiq_secret@localhost:5432/hireiq
# UPLOAD_DIR=./uploads
# DEBUG=true
